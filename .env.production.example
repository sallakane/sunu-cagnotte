COMPOSE_PROJECT_NAME=cagnotte

APP_ENV=prod
APP_SECRET=change-me
APP_BASE_URL=https://sunu-cagnotte.org
FRONTEND_BASE_URL=https://sunu-cagnotte.org
NGINX_SERVER_NAME="sunu-cagnotte.org www.sunu-cagnotte.org"
NGINX_CANONICAL_HOST=sunu-cagnotte.org
ENABLE_TLS=0
SSL_CERTS_HOST_PATH=./infra/nginx/certs
SSL_CERT_PATH=/etc/nginx/certs/fullchain.pem
SSL_CERT_KEY_PATH=/etc/nginx/certs/privkey.pem

DATABASE_NAME=cagnotte
DATABASE_USER=cagnotte
DATABASE_PASSWORD=change-me
DATABASE_PORT=5432

# URL-encode the mailbox password inside the DSN when it contains special characters.
MAILER_DSN=smtp://no-reply%40sunu-cagnotte.org:change-me@smtp.hostinger.com:587
MAIL_FROM_ADDRESS=no-reply@sunu-cagnotte.org
MAIL_FROM_NAME="Sunu Cagnotte"
CONTACT_RECIPIENT=ndiageze@gmail.com

JWT_PASSPHRASE=change-this-passphrase

PAYMENT_PROVIDER=paydunya
PAYDUNYA_MODE=live
PAYDUNYA_MASTER_KEY=live-master-key
PAYDUNYA_PRIVATE_KEY=live-private-key
PAYDUNYA_PUBLIC_KEY=live-public-key
PAYDUNYA_TOKEN=live-token
PAYDUNYA_STORE_NAME="Sunu Cagnotte"
PAYDUNYA_STORE_TAGLINE="Une plateforme solidaire pensee pour le Senegal"

VITE_API_BASE_URL=/api
VITE_APP_NAME="Sunu Cagnotte"
VITE_SITE_URL=https://sunu-cagnotte.org
