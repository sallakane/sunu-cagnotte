{% extends 'emails/base.html.twig' %}

{% set eyebrow = 'Échéance proche' %}
{% set intro = 'Votre campagne approche de sa date de clôture. Voici un rappel rapide pour suivre sa progression.' %}

{% block title %}Votre cagnotte se termine bientôt{% endblock %}

{% block content %}
  <p style="margin:0 0 18px;font-size:16px;line-height:1.7;color:#334155;">
    Bonjour {{ owner.firstName }},
  </p>

  <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#334155;">
    La cagnotte <strong style="color:#0f172a;">{{ fundraiser.title }}</strong> arrive bientôt à échéance.
  </p>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:22px;">
    <tr>
      <td style="padding:16px 18px;border:1px solid #dbe7e5;border-radius:18px;background:#ffffff;">
        <p style="margin:0 0 10px;font-size:14px;line-height:1.6;color:#475569;"><strong style="color:#0f172a;">Date de fin :</strong> {{ fundraiser.endDate|date('d/m/Y') }}</p>
        <p style="margin:0;font-size:14px;line-height:1.6;color:#475569;"><strong style="color:#0f172a;">Montant collecté :</strong> {{ fundraiser.collectedAmount|number_format(0, ',', ' ') }} {{ fundraiser.currency }}</p>
      </td>
    </tr>
  </table>

  <a href="{{ dashboardUrl }}" style="display:inline-block;padding:14px 18px;border-radius:999px;background:{{ brandPrimaryColor }};color:#ffffff;text-decoration:none;font-size:14px;font-weight:700;">
    Voir ma cagnotte
  </a>
{% endblock %}
