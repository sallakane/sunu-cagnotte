{% extends 'emails/base.html.twig' %}

{% set eyebrow = 'Contact' %}
{% set intro = 'Un nouveau message a ete envoye depuis le formulaire public. Les informations essentielles sont recapitulees ci-dessous.' %}

{% block title %}Nouveau message de contact{% endblock %}

{% block content %}
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:20px;">
    <tr>
      <td style="padding:16px 18px;border:1px solid #dbe7e5;border-radius:18px;background:#ffffff;">
        <p style="margin:0 0 10px;font-size:14px;line-height:1.6;color:#475569;"><strong style="color:#0f172a;">Nom :</strong> {{ contactMessage.name }}</p>
        <p style="margin:0 0 10px;font-size:14px;line-height:1.6;color:#475569;"><strong style="color:#0f172a;">Email :</strong> {{ contactMessage.email }}</p>
        <p style="margin:0 0 10px;font-size:14px;line-height:1.6;color:#475569;"><strong style="color:#0f172a;">Telephone :</strong> {{ contactMessage.phone ?: 'Non renseigne' }}</p>
        <p style="margin:0;font-size:14px;line-height:1.6;color:#475569;"><strong style="color:#0f172a;">Sujet :</strong> {{ contactMessage.subject }}</p>
      </td>
    </tr>
  </table>

  <div style="padding:18px 20px;border-radius:20px;background:#fffbeb;border:1px solid #fde68a;">
    <p style="margin:0 0 10px;font-size:13px;line-height:1.5;color:#92400e;text-transform:uppercase;letter-spacing:0.08em;font-weight:700;">
      Message
    </p>
    <div style="font-size:15px;line-height:1.75;color:#3f3f46;">
      {{ contactMessage.message|nl2br }}
    </div>
  </div>
{% endblock %}
