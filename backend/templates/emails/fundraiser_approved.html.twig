{% extends 'emails/base.html.twig' %}

{% set eyebrow = 'Cagnotte validée' %}
{% set intro = 'Bonne nouvelle ! Votre cagnotte vient d'être validée par notre équipe et est désormais visible par tous.' %}

{% block title %}Votre cagnotte est en ligne 🎉{% endblock %}

{% block content %}
  <p style="margin:0 0 18px;font-size:16px;line-height:1.7;color:#334155;">
    Bonjour {{ owner.firstName }},
  </p>

  <div style="margin-bottom:22px;padding:18px 20px;border-radius:20px;background:#f0fdf4;border:1px solid #bbf7d0;">
    <p style="margin:0 0 6px;font-size:13px;line-height:1.5;color:#15803d;text-transform:uppercase;letter-spacing:0.08em;font-weight:700;">
      ✅ Publiée et accessible
    </p>
    <p style="margin:0;font-size:22px;line-height:1.3;color:#0f172a;font-weight:700;">
      {{ fundraiser.title }}
    </p>
  </div>

  <p style="margin:0 0 16px;font-size:15px;line-height:1.7;color:#334155;">
    Maintenant que votre cagnotte est en ligne, votre plus grande force c'est <strong>votre réseau</strong>. Partagez-la à tous vos contacts — famille, amis, collègues — via WhatsApp, Facebook, SMS ou directement de la main à la main.
  </p>

  <p style="margin:0 0 22px;font-size:15px;line-height:1.7;color:#334155;">
    Pour maximiser les dons, pensez également à :
  </p>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
    <tr>
      <td style="padding:10px 14px;background:#f8fafc;border-radius:14px;border:1px solid #dbe7e5;margin-bottom:10px;display:block;">
        <p style="margin:0;font-size:14px;line-height:1.6;color:#0f172a;">
          🖼️ <strong>Ajouter une belle photo de couverture</strong> — une image forte attire l'attention et inspire confiance.
        </p>
      </td>
    </tr>
    <tr><td style="height:8px;"></td></tr>
    <tr>
      <td style="padding:10px 14px;background:#f8fafc;border-radius:14px;border:1px solid #dbe7e5;">
        <p style="margin:0;font-size:14px;line-height:1.6;color:#0f172a;">
          ✍️ <strong>Enrichir la description</strong> — expliquez votre histoire avec émotion, donnez des détails concrets sur l'impact des dons.
        </p>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" style="margin-bottom:14px;">
    <tr>
      <td style="border-radius:999px;background:{{ brandPrimaryColor }};">
        <a href="{{ fundraiserUrl }}" style="display:inline-block;padding:14px 22px;color:#ffffff;text-decoration:none;font-size:14px;font-weight:700;">
          Voir ma cagnotte en ligne
        </a>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
    <tr>
      <td style="border-radius:999px;background:#f1f5f9;border:1px solid #dbe7e5;">
        <a href="{{ editUrl }}" style="display:inline-block;padding:13px 22px;color:{{ brandPrimaryColor }};text-decoration:none;font-size:14px;font-weight:700;">
          Modifier ma cagnotte (photo, description…)
        </a>
      </td>
    </tr>
  </table>

  <p style="margin:0;font-size:14px;line-height:1.7;color:#64748b;">
    Merci pour votre confiance et bonne collecte !<br>
    <strong>L'équipe Sunu Cagnotte</strong>
  </p>
{% endblock %}
