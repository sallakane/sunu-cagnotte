{% extends 'emails/base.html.twig' %}

{% set eyebrow = 'Nouvelle cagnotte — à valider' %}
{% set intro = 'Une nouvelle cagnotte vient d\'être soumise et attend votre validation avant publication.' %}

{% block title %}{{ fundraiser.title }}{% endblock %}

{% block content %}
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:16px;">
    <tr>
      <td style="padding:16px 18px;border:1px solid #dbe7e5;border-radius:18px;background:#ffffff;">
        <p style="margin:0 0 10px;font-size:14px;line-height:1.6;color:#475569;"><strong style="color:#0f172a;">Porteur :</strong> {{ owner.firstName }} {{ owner.lastName }}</p>
        <p style="margin:0 0 10px;font-size:14px;line-height:1.6;color:#475569;"><strong style="color:#0f172a;">Email :</strong> {{ owner.email }}</p>
        <p style="margin:0 0 10px;font-size:14px;line-height:1.6;color:#475569;"><strong style="color:#0f172a;">Objectif :</strong> {{ fundraiser.targetAmount|number_format(0, ',', ' ') }} {{ fundraiser.currency }}</p>
        <p style="margin:0 0 10px;font-size:14px;line-height:1.6;color:#475569;"><strong style="color:#0f172a;">Clôture :</strong> {{ fundraiser.endDate|date('d/m/Y') }}</p>
        {% if fundraiser.category %}
          <p style="margin:0;font-size:14px;line-height:1.6;color:#475569;"><strong style="color:#0f172a;">Catégorie :</strong> {{ fundraiser.category }}</p>
        {% endif %}
      </td>
    </tr>
  </table>

  <div style="padding:18px 20px;border-radius:20px;background:#fffbeb;border:1px solid #fde68a;margin-bottom:20px;">
    <p style="margin:0 0 10px;font-size:13px;line-height:1.5;color:#92400e;text-transform:uppercase;letter-spacing:0.08em;font-weight:700;">
      Description
    </p>
    <div style="font-size:15px;line-height:1.75;color:#3f3f46;">
      {{ fundraiser.description|nl2br|slice(0, 500) }}{% if fundraiser.description|length > 500 %}…{% endif %}
    </div>
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center">
        <a href="{{ adminUrl }}" style="display:inline-block;padding:14px 28px;background:{{ brandPrimaryColor }};color:#ffffff;text-decoration:none;border-radius:999px;font-size:15px;font-weight:700;">
          Accéder au panneau admin
        </a>
      </td>
    </tr>
  </table>
{% endblock %}
