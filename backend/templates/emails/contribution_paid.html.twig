{% extends 'emails/base.html.twig' %}

{% set eyebrow = 'Contribution' %}
{% set intro = 'Votre paiement a été confirmé. Merci pour votre participation à cette campagne solidaire.' %}

{% block title %}Contribution confirmée{% endblock %}

{% block content %}
  <p style="margin:0 0 18px;font-size:16px;line-height:1.7;color:#334155;">
    Bonjour {{ contribution.firstName }},
  </p>

  <div style="margin-bottom:20px;padding:18px 20px;border-radius:20px;background:#ecfeff;border:1px solid #a5f3fc;">
    <p style="margin:0 0 8px;font-size:13px;line-height:1.5;color:#0f766e;text-transform:uppercase;letter-spacing:0.08em;font-weight:700;">
      Montant confirmé
    </p>
    <p style="margin:0;font-size:28px;line-height:1.2;color:#0f172a;font-weight:700;">
      {{ contribution.amountGross|number_format(0, ',', ' ') }} {{ fundraiser.currency }}
    </p>
  </div>

  <p style="margin:0 0 12px;font-size:15px;line-height:1.7;color:#334155;">
    Votre contribution pour la cagnotte <strong style="color:#0f172a;">{{ fundraiser.title }}</strong> a bien été enregistrée.
  </p>
  <p style="margin:0 0 22px;font-size:15px;line-height:1.7;color:#334155;">
    Référence de paiement : <strong style="color:#0f172a;">{{ contribution.paymentReference }}</strong>
  </p>

  <a href="{{ fundraiserUrl }}" style="display:inline-block;padding:14px 18px;border-radius:999px;background:{{ brandPrimaryColor }};color:#ffffff;text-decoration:none;font-size:14px;font-weight:700;">
    Voir la cagnotte
  </a>
{% endblock %}
