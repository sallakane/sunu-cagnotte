{% extends 'emails/base.html.twig' %}

{% set eyebrow = 'Securite du compte' %}
{% set intro = 'Une demande de reinitialisation de mot de passe a ete recue pour votre espace createur.' %}

{% block title %}Reinitialiser votre mot de passe{% endblock %}

{% block content %}
  <p style="margin:0 0 18px;font-size:16px;line-height:1.7;color:#334155;">
    Bonjour {{ user.firstName }},
  </p>

  <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#334155;">
    Si vous etes a l origine de cette demande, utilisez le bouton ci-dessous pour definir un nouveau mot de passe.
  </p>

  <a href="{{ resetUrl }}" style="display:inline-block;padding:14px 18px;border-radius:999px;background:{{ brandPrimaryColor }};color:#ffffff;text-decoration:none;font-size:14px;font-weight:700;">
    Reinitialiser mon mot de passe
  </a>

  <p style="margin:22px 0 0;font-size:14px;line-height:1.7;color:#475569;">
    Ce lien expire dans 1 heure. Si vous n avez pas demande de reinitialisation, vous pouvez ignorer cet email.
  </p>
{% endblock %}
